{
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "customConditions": ["source"],
    "allowImportingTsExtensions": true,
    "target": "ES2021",
    "lib": ["ES2021"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["src/index.ts"]
}
